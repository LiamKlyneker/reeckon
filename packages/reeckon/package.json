{
  "name": "reeckon",
  "version": "0.3.0",
  "description": "A centralized AI skill registry for your team. Write once and integrate instantly with Claude, Cursor, Antigravity, and other LLM tools.",
  "keywords": [
    "ai",
    "skills",
    "registry",
    "claude",
    "cursor",
    "codex",
    "antigravity",
    "agents",
    "llm",
    "cli",
    "developer-tools"
  ],
  "author": "Liam Klyneker <liamklyneker@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/LiamKlyneker/reeckon#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiamKlyneker/reeckon.git",
    "directory": "packages/reeckon"
  },
  "bugs": {
    "url": "https://github.com/LiamKlyneker/reeckon/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "bin": {
    "reeckon": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/viewer",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "link:global": "pnpm build && pnpm link --global"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.5",
    "@fontsource/ibm-plex-sans": "^5.2.5",
    "@tailwindcss/vite": "^4",
    "@vitejs/plugin-react": "^4.5.2",
    "cac": "^7.0.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.5.0",
    "typescript": "5.9.3"
  }
}
